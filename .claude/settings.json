{
  "permissions": {
    "allow": [
      "Bash(dotnet:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh run:*)",
      "Bash(gh pr:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-plan.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/require-phase-qc.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-review.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/require-analyse.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/bash-logger.sh PRE"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/agent-logger.sh START"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/agent-logger.sh DONE"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/bash-logger.sh POST"
          }
        ]
      }
    ]
  }
}
